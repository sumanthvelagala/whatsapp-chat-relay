# Your WhatsApp number that will RECEIVE the messages.
# Format: country code + number, no + or spaces.
# Example: 14155552671 for US +1 (415) 555-2671
WA_RECIPIENT=your_whatsapp_number

# Anthropic API key for the Claude AI bot (get one at console.anthropic.com)
# If not set, the bot is disabled and only human replies will work.
ANTHROPIC_API_KEY=your_anthropic_api_key

# How many seconds to wait before the bot auto-replies (default: 8)
# BOT_DELAY_SECONDS=8

# Optional: secret token — clients must pass ?token=xxx to connect
# API_SECRET=your_secret_token

# Optional: comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://yoursite.com,https://www.yoursite.com

# Optional: path to Chrome if puppeteer can't find it automatically
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional: port for the server (default: 3001)
# PORT=3001
